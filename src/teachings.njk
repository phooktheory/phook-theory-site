---
layout: layout.njk
pageTitle: Teachings
currentPage: /teachings/
---

<!-- ── PALETTE STRIP ── -->
<div class="palette-strip">
  <div class="ps" style="background:#0A1A30"></div>
  <div class="ps" style="background:#152E5E"></div>
  <div class="ps" style="background:#C4580A"></div>
  <div class="ps" style="background:#D4920A"></div>
  <div class="ps" style="background:#6ABAE0"></div>
  <div class="ps" style="background:#2A9E6A"></div>
  <div class="ps" style="background:#F0E6D2"></div>
</div>

<!-- ── PAGE HERO ── -->
<div class="page-hero">
  <p class="page-hero-eyebrow">Three Teaching Arms</p>
  <h1 class="page-hero-title">The Phook Theory<br><em>Framework</em></h1>
  <p class="page-hero-sub">Every teaching asks the same question: what are you holding that your breath could release? Three arms. One breath.</p>
</div>

<!-- ── THREE ARMS OVERVIEW ── -->
<section class="section teachings">
  <div class="container">
    <p class="section-label" style="color:var(--sky)">The Framework</p>
    <h2 class="section-title" style="color:var(--beige)">Three ways to work with breath</h2>
    <div class="teaching-cards">
      {% for card in site.teachings.cards %}
      <div class="teaching-card {{ card.cardClass }}">
        <div class="tc-icon">{{ card.icon }}</div>
        <div class="tc-label">{{ card.label }}</div>
        <div class="tc-title">{{ card.title }}</div>
        <p class="tc-desc">{{ card.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ── THE PHOOK PRINCIPLES ── -->
<section class="section principles">
  <div class="container">
    <p class="section-label">Universal Laws</p>
    <h2 class="section-title">The Phook Principles</h2>
    <p class="section-body">Seven laws. Accessible to all traditions, backgrounds, and beliefs. The universal truth that every wisdom culture has understood: your breath and attention shape your reality.</p>
    <div class="principle-grid">
      {% for item in site.principles.items %}
      <div class="principle-card">
        <div class="p-num">{{ item.num }}</div>
        <div class="p-title">{{ item.title }}</div>
        <p class="p-text">{{ item.text }}</p>
      </div>
      {% endfor %}
    </div>
    <div style="margin-top:2.5rem;text-align:center">
      <a href="/shop/" class="btn-primary">Get The Phook Principles — $14.99</a>
    </div>
  </div>
</section>

<!-- ── CRYSTAL CLEARING ── -->
<section class="section crystal">
  <div class="container">
    <p class="section-label" style="color:var(--jade)">Metaphysical</p>
    <h2 class="section-title" style="color:var(--beige)">The Crystal Phook Clearing</h2>
    <p class="section-body" style="color:rgba(240,230,210,0.6);margin-bottom:0.5rem">Tools to remove what blocks you. Crystals, space clearing, body energy work, and ritual design — practical anchors for intention.</p>
    <div class="crystal-grid">
      {% for item in site.crystal.items %}
      <div class="crystal-card">
        <div class="crystal-gem">{{ item.emoji }}</div>
        <div class="crystal-name">{{ item.name }}</div>
        <p class="crystal-desc">{{ item.desc }}</p>
      </div>
      {% endfor %}
    </div>
    <div style="margin-top:2.5rem;display:flex;gap:1rem;flex-wrap:wrap">
      <a href="/shop/" class="btn-primary">The Crystal Phook Clearing — $14.99</a>
      <a href="/shop/" class="btn-ghost" style="color:var(--jade);border-color:var(--jade)">Get the Starter Kit — $49</a>
    </div>
  </div>
</section>

<!-- ── PHOOK THE DRAMA ── -->
<section class="section drama">
  <div class="container">
    <p class="section-label">Group & Collective</p>
    <h2 class="section-title">Phook the Drama</h2>
    <p class="section-body">Ego-free collective energy and group flow. Eight modules for teams, workplaces, schools, and any group of humans trying to function together without the drama.</p>
    <div class="module-grid">
      {% for mod in site.drama.modules %}
      <div class="module-card">
        <div class="module-num">{{ mod.num }}</div>
        <div class="module-title">{{ mod.title }}</div>
        <p class="module-text">{{ mod.text }}</p>
      </div>
      {% endfor %}
    </div>
    <div style="margin-top:2.5rem;display:flex;gap:1rem;flex-wrap:wrap">
      <a href="/shop/" class="btn-primary">Full Course — $149</a>
      <a href="/contact/" class="btn-ghost" style="border-color:var(--copper);color:var(--copper)">Corporate Packages →</a>
    </div>
  </div>
</section>
