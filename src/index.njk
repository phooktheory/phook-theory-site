---
layout: layout.njk
currentPage: /
---

<!-- ── HERO ── -->
<section class="hero" style="min-height:92vh;background:var(--navy);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:5rem 2rem 4rem;position:relative;overflow:hidden">
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:0">
    <div style="position:absolute;border-radius:50%;transform:translate(-50%,-50%);opacity:0;animation:expand 5s ease-out infinite;width:120px;height:120px;border:1px solid rgba(196,88,10,0.5);animation-delay:0s"></div>
    <div style="position:absolute;border-radius:50%;transform:translate(-50%,-50%);opacity:0;animation:expand 5s ease-out infinite;width:280px;height:280px;border:1px solid rgba(106,186,224,0.3);animation-delay:1s"></div>
    <div style="position:absolute;border-radius:50%;transform:translate(-50%,-50%);opacity:0;animation:expand 5s ease-out infinite;width:460px;height:460px;border:1px solid rgba(42,158,106,0.2);animation-delay:2s"></div>
    <div style="position:absolute;border-radius:50%;transform:translate(-50%,-50%);opacity:0;animation:expand 5s ease-out infinite;width:660px;height:660px;border:0.5px solid rgba(196,88,10,0.12);animation-delay:3s"></div>
  </div>

  <div style="margin:0 auto 2rem;position:relative;z-index:1">
    <svg width="160" height="160" viewBox="-90 -96 180 180" xmlns="http://www.w3.org/2000/svg" style="overflow:visible">
      <g style="transform-origin:0 0" class="mark-anim">
        <path d="M0 14 Q1 44 2 80" stroke="rgba(196,88,10,0.4)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <line x1="0" y1="0" x2="0"   y2="-68" stroke="#F0E6D2" stroke-width="1.1" stroke-linecap="round"/>
        <line x1="0" y1="-54" x2="-9" y2="-66" stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <line x1="0" y1="-54" x2="9"  y2="-66" stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <circle cx="0"  cy="-71" r="3.5" fill="#F0E6D2"/>
        <circle cx="-9" cy="-69" r="3"   fill="#F0E6D2"/>
        <circle cx="9"  cy="-69" r="3"   fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="59"  y2="-34" stroke="#F0E6D2" stroke-width="1.1" stroke-linecap="round"/>
        <line x1="46" y1="-27" x2="54" y2="-38" stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <line x1="46" y1="-27" x2="61" y2="-31" stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <circle cx="62" cy="-36" r="3.5" fill="#F0E6D2"/>
        <circle cx="54" cy="-41" r="3"   fill="#F0E6D2"/>
        <circle cx="63" cy="-31" r="3"   fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="59"  y2="34"  stroke="#F0E6D2" stroke-width="1.1" stroke-linecap="round"/>
        <line x1="46" y1="27" x2="54" y2="38"  stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <line x1="46" y1="27" x2="61" y2="31"  stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <circle cx="62" cy="36"  r="3.5" fill="#F0E6D2"/>
        <circle cx="54" cy="41"  r="3"   fill="#F0E6D2"/>
        <circle cx="63" cy="31"  r="3"   fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="0"   y2="68"  stroke="#F0E6D2" stroke-width="1.1" stroke-linecap="round"/>
        <line x1="0" y1="54" x2="-9" y2="66"  stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <line x1="0" y1="54" x2="9"  y2="66"  stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <circle cx="0"  cy="71"  r="3.5" fill="#F0E6D2"/>
        <circle cx="-9" cy="69"  r="3"   fill="#F0E6D2"/>
        <circle cx="9"  cy="69"  r="3"   fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="-59" y2="34"  stroke="#F0E6D2" stroke-width="1.1" stroke-linecap="round"/>
        <line x1="-46" y1="27" x2="-61" y2="31" stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <line x1="-46" y1="27" x2="-54" y2="38" stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <circle cx="-62" cy="36"  r="3.5" fill="#F0E6D2"/>
        <circle cx="-63" cy="31"  r="3"   fill="#F0E6D2"/>
        <circle cx="-54" cy="41"  r="3"   fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="-59" y2="-34" stroke="#F0E6D2" stroke-width="1.1" stroke-linecap="round"/>
        <line x1="-46" y1="-27" x2="-61" y2="-31" stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <line x1="-46" y1="-27" x2="-54" y2="-38" stroke="#F0E6D2" stroke-width="0.8" stroke-linecap="round"/>
        <circle cx="-62" cy="-36" r="3.5" fill="#F0E6D2"/>
        <circle cx="-63" cy="-31" r="3"   fill="#F0E6D2"/>
        <circle cx="-54" cy="-41" r="3"   fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="22"  y2="-38" stroke="#F0E6D2" stroke-width="0.85" stroke-linecap="round"/><circle cx="23"  cy="-40" r="2.5" fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="44"  y2="0"   stroke="#F0E6D2" stroke-width="0.85" stroke-linecap="round"/><circle cx="46"  cy="0"   r="2.5" fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="22"  y2="38"  stroke="#F0E6D2" stroke-width="0.85" stroke-linecap="round"/><circle cx="23"  cy="40"  r="2.5" fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="-22" y2="38"  stroke="#F0E6D2" stroke-width="0.85" stroke-linecap="round"/><circle cx="-23" cy="40"  r="2.5" fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="-44" y2="0"   stroke="#F0E6D2" stroke-width="0.85" stroke-linecap="round"/><circle cx="-46" cy="0"   r="2.5" fill="#F0E6D2"/>
        <line x1="0" y1="0" x2="-22" y2="-38" stroke="#F0E6D2" stroke-width="0.85" stroke-linecap="round"/><circle cx="-23" cy="-40" r="2.5" fill="#F0E6D2"/>
        <path d="M0 -15 C-8 -11 -10.5 -3 -8 3.5 C-5 10 5 10 8 3.5 C10.5 -3 8 -11 0 -15Z" fill="#F0E6D2"/>
        <path d="M0 -10 C-5.2 -7 -6.8 -1.5 -5.2 3 C-3.2 8 3.2 8 5.2 3 C6.8 -1.5 5.2 -7 0 -10Z" fill="#0A1A30"/>
        <path d="M0 -6 C-3.2 -4 -4 -0.8 -3 1.8 C-2 4.5 2 4.5 3 1.8 C4 -0.8 3.2 -4 0 -6Z" fill="#F0E6D2"/>
        <circle cx="0" cy="1.5" r="1.8" fill="#0A1A30"/>
        <circle cx="-0.5" cy="0.5" r="0.65" fill="white" opacity="0.45"/>
      </g>
    </svg>
  </div>

  <p style="font-size:0.7rem;font-weight:600;letter-spacing:4px;text-transform:uppercase;color:var(--sky);margin-bottom:1.5rem;position:relative;z-index:1">{{ site.hero.eyebrow }}</p>
  <h1 style="font-family:'Playfair Display',serif;font-size:clamp(3.2rem,10vw,7rem);font-weight:900;line-height:0.92;color:var(--beige);margin-bottom:0.5rem;position:relative;z-index:1;letter-spacing:-1px">{{ site.hero.titleLine1 }}<br><span style="color:var(--copper)">{{ site.hero.titleLine2 }}</span></h1>
  <p style="font-size:1.05rem;color:rgba(240,230,210,0.6);max-width:480px;line-height:1.85;margin:1.5rem auto 2.5rem;position:relative;z-index:1">{{ site.hero.subtitle }}</p>
  <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;position:relative;z-index:1">
    <a href="/shop/" class="btn-primary">{{ site.hero.primaryBtnLabel }}</a>
    <a href="/app/" class="btn-ghost">{{ site.hero.ghostBtnLabel }}</a>
  </div>
</section>

<style>
@keyframes expand{
  0%{opacity:0;transform:translate(-50%,-50%) scale(0.1)}
  20%{opacity:1}
  100%{opacity:0;transform:translate(-50%,-50%) scale(1)}
}
</style>

<!-- palette strip -->
<div class="palette-strip">
  <div class="ps" style="background:#0A1A30"></div>
  <div class="ps" style="background:#152E5E"></div>
  <div class="ps" style="background:#C4580A"></div>
  <div class="ps" style="background:#D4920A"></div>
  <div class="ps" style="background:#6ABAE0"></div>
  <div class="ps" style="background:#2A9E6A"></div>
  <div class="ps" style="background:#F0E6D2"></div>
</div>

<!-- ── ABOUT ── -->
<section class="section about" id="about">
  <div class="container">
    <div class="two-col">
      <div>
        <p class="section-label">{{ site.about.label }}</p>
        <h2 class="section-title">{{ site.about.title }}</h2>
        <p class="section-body">{{ site.about.body1 }}</p>
        <div class="pull-quote">"{{ site.about.pullQuote }}"</div>
        <p class="section-body">{{ site.about.body2 }}</p>
        <div style="margin-top:1.5rem">
          <a href="/teachings/" class="btn-primary">{{ site.about.ctaLabel }}</a>
        </div>
      </div>
      <div>
        <div class="stat-grid">
          {% for stat in site.about.stats %}
          <div class="stat-card"><div class="stat-num">{{ stat.num }}</div><div class="stat-label">{{ stat.label }}</div></div>
          {% endfor %}
        </div>
        <div style="margin-top:1.25rem;background:var(--cream);border:1px solid var(--border);border-radius:6px;padding:1.25rem">
          <p style="font-size:0.7rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--copper);margin-bottom:0.5rem">{{ site.about.lawBoxLabel }}</p>
          <p style="font-family:'Playfair Display',serif;font-size:0.95rem;color:var(--navy);line-height:1.6;font-style:italic">"{{ site.about.lawBoxQuote }}"</p>
          <p style="font-size:0.78rem;color:var(--smoke);margin-top:0.5rem;line-height:1.7;opacity:0.7">{{ site.about.lawBoxBody }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── SHOP ── -->
<section class="section shop" id="shop">
  <div class="container">
    <p class="section-label">{{ site.shop.label }}</p>
    <h2 class="section-title">{{ site.shop.title }}</h2>
    <div class="book-grid">
      {% for book in site.shop.books %}
      <div class="book-card">
        <div class="book-cover {{ book.colorClass }}"><div class="book-cover-title">{{ book.title }}</div></div>
        <div class="book-body">
          <div class="book-tag">{{ book.tag }}</div>
          <div style="font-family:'Playfair Display',serif;font-size:0.9rem;font-weight:700;color:var(--navy)">{{ book.title }}</div>
          <div class="book-price">{{ book.price }}</div>
          <button class="book-btn">Buy Now</button>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ── TEACHINGS ── -->
<section class="section teachings" id="teachings">
  <div class="container">
    <p class="section-label" style="color:var(--sky)">{{ site.teachings.label }}</p>
    <h2 class="section-title" style="color:var(--beige)">{{ site.teachings.title }}</h2>
    <p class="section-body" style="color:rgba(240,230,210,0.6)">{{ site.teachings.body }}</p>
    <div class="teaching-cards">
      {% for card in site.teachings.cards %}
      <div class="teaching-card {{ card.cardClass }}">
        <div class="tc-icon">{{ card.icon }}</div>
        <div class="tc-label">{{ card.label }}</div>
        <div class="tc-title">{{ card.title }}</div>
        <p class="tc-desc">{{ card.desc }}</p>
        <a href="/teachings/" class="tc-link">{{ card.linkLabel }}</a>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ── PHOOK PRINCIPLES ── -->
<section class="section principles" id="principles">
  <div class="container">
    <p class="section-label">{{ site.principles.label }}</p>
    <h2 class="section-title">{{ site.principles.title }}</h2>
    <p class="section-body">{{ site.principles.body }}</p>
    <div class="principle-grid">
      {% for item in site.principles.items %}
      <div class="principle-card">
        <div class="p-num">{{ item.num }}</div>
        <div class="p-title">{{ item.title }}</div>
        <p class="p-text">{{ item.text }}</p>
      </div>
      {% endfor %}
    </div>
    <div style="margin-top:2.5rem;text-align:center">
      <a href="/shop/" class="btn-primary">{{ site.principles.ctaLabel }}</a>
    </div>
  </div>
</section>

<!-- ── CRYSTAL ── -->
<section class="section crystal" id="crystal">
  <div class="container">
    <p class="section-label" style="color:var(--jade)">{{ site.crystal.label }}</p>
    <h2 class="section-title" style="color:var(--beige)">{{ site.crystal.title }}</h2>
    <p class="section-body" style="color:rgba(240,230,210,0.6);margin-bottom:0.5rem">{{ site.crystal.body }}</p>
    <div class="crystal-grid">
      {% for item in site.crystal.items %}
      <div class="crystal-card">
        <div class="crystal-gem">{{ item.emoji }}</div>
        <div class="crystal-name">{{ item.name }}</div>
        <p class="crystal-desc">{{ item.desc }}</p>
      </div>
      {% endfor %}
    </div>
    <div style="margin-top:2.5rem;display:flex;gap:1rem;flex-wrap:wrap">
      <a href="/shop/" class="btn-primary">{{ site.crystal.primaryBtnLabel }}</a>
      <a href="/shop/" class="btn-ghost" style="color:var(--jade);border-color:var(--jade)">{{ site.crystal.ghostBtnLabel }}</a>
    </div>
  </div>
</section>

<!-- ── PHOOK THE DRAMA ── -->
<section class="section drama" id="drama">
  <div class="container">
    <p class="section-label">{{ site.drama.label }}</p>
    <h2 class="section-title">{{ site.drama.title }}</h2>
    <p class="section-body">{{ site.drama.body }}</p>
    <div class="module-grid">
      {% for mod in site.drama.modules %}
      <div class="module-card">
        <div class="module-num">{{ mod.num }}</div>
        <div class="module-title">{{ mod.title }}</div>
        <p class="module-text">{{ mod.text }}</p>
      </div>
      {% endfor %}
    </div>
    <div style="margin-top:2.5rem;display:flex;gap:1rem;flex-wrap:wrap">
      <a href="/shop/" class="btn-primary">{{ site.drama.primaryBtnLabel }}</a>
      <a href="/contact/" class="btn-ghost" style="border-color:var(--copper);color:var(--copper)">{{ site.drama.ghostBtnLabel }}</a>
    </div>
  </div>
</section>

<!-- ── APP ── -->
<section class="section app-sec" id="app">
  <div class="container">
    <div class="two-col">
      <div>
        <p class="section-label">{{ site.app.label }}</p>
        <h2 class="section-title">{{ site.app.title }}</h2>
        <p class="section-body">{{ site.app.body }}</p>
        <div class="feat-list">
          {% for feat in site.app.features %}
          <div class="feat-row"><div class="feat-dot {{ feat.dotClass }}"></div><span>{{ feat.text }}</span></div>
          {% endfor %}
        </div>
        <div class="waitlist-row">
          <input class="waitlist-input" type="email" placeholder="{{ site.app.waitlistPlaceholder }}"/>
          <button class="btn-primary">{{ site.app.waitlistBtnLabel }}</button>
        </div>
      </div>
      <div>
        <div class="app-mockup">
          <div class="app-top">
            <span class="app-logo-text">{{ site.meta.brandName }}</span>
            <span class="ego-badge">{{ site.app.mockup.egoBadge }}</span>
          </div>
          <div class="ego-meter">
            <div class="meter-label">{{ site.app.mockup.meterLabel }}</div>
            <div class="meter-bar"><div class="meter-fill" style="width:{{ site.app.mockup.meterFillPct }}"></div></div>
            <div class="meter-result">{{ site.app.mockup.meterResult }}</div>
          </div>
          <div class="daily-card">
            <span class="daily-tag">{{ site.app.mockup.dailyTag }}</span>
            <div class="daily-text">{{ site.app.mockup.dailyText }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── PHOOK IT SERIES ── -->
<section class="section series" id="series">
  <div class="container">
    <p class="section-label" style="color:var(--sky)">{{ site.series.label }}</p>
    <h2 class="section-title" style="color:var(--beige)">{{ site.series.title }}</h2>
    <div class="series-grid">
      {% for item in site.series.items %}
      <div class="series-card">
        <span class="series-type">{{ item.type }}</span>
        <div class="series-title">{{ item.title }}</div>
        <div class="series-price">{{ item.price }}</div>
      </div>
      {% endfor %}
    </div>
    <div class="series-bundle">
      <div class="bundle-text">
        <div class="bundle-title">{{ site.series.bundle.title }}</div>
        <div class="bundle-sub">{{ site.series.bundle.sub }}</div>
      </div>
      <div>
        <div class="bundle-price">{{ site.series.bundle.price }}</div>
        <div class="bundle-save">{{ site.series.bundle.save }}</div>
      </div>
      <a href="/shop/" class="btn-primary">{{ site.series.bundle.ctaLabel }}</a>
    </div>
  </div>
</section>

<!-- ── TESTIMONIALS ── -->
<section class="section testimonials">
  <div class="container">
    <p class="section-label">{{ site.testimonials.label }}</p>
    <h2 class="section-title">{{ site.testimonials.title }}</h2>
    <div class="test-grid">
      {% for t in site.testimonials.items %}
      <div class="test-card">
        <div class="test-quote">{{ t.quote }}</div>
        <div class="test-name">{{ t.name }}</div>
        <div class="test-title">{{ t.title }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ── AFFILIATE ── -->
<section class="section affiliate" id="affiliate">
  <div class="container">
    <p class="section-label">{{ site.affiliate.label }}</p>
    <h2 class="section-title">{{ site.affiliate.title }}</h2>
    <p class="section-body">{{ site.affiliate.body }}</p>
    <div class="tier-grid">
      {% for tier in site.affiliate.tiers %}
      <div class="tier-card {{ tier.cardClass }}">
        <div class="tier-icon-wrap {{ tier.iconClass }}">
          <svg width="28" height="28" viewBox="0 0 28 28"><text y="22" font-size="22">{{ tier.emoji }}</text></svg>
        </div>
        <div class="tier-name">{{ tier.name }}</div>
        <div class="tier-label">{{ tier.label }}</div>
        <div class="tier-pct">{{ tier.pct }}<sup>%</sup></div>
        <p class="tier-desc">{{ tier.desc }}</p>
      </div>
      {% endfor %}
    </div>
    <div style="margin-top:2.5rem;text-align:center">
      <a href="/contact/" class="btn-primary">{{ site.affiliate.ctaLabel }}</a>
    </div>
  </div>
</section>

<!-- ── NEWSLETTER ── -->
<section class="section newsletter" id="contact">
  <div class="container">
    <div class="two-col">
      <div>
        <p class="section-label">{{ site.newsletter.label }}</p>
        <h2 class="section-title">{{ site.newsletter.title }}</h2>
        <p class="section-body">{{ site.newsletter.body }}</p>
        <div class="nl-form">
          <input class="nl-input" type="email" placeholder="{{ site.newsletter.emailPlaceholder }}"/>
          <button class="nl-btn">{{ site.newsletter.subscribeBtnLabel }}</button>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:1rem">
        <div style="background:rgba(255,255,255,0.1);border-radius:8px;padding:1.25rem">
          <p style="font-size:0.65rem;font-weight:700;letter-spacing:2px;color:rgba(255,255,255,0.6);margin-bottom:0.4rem">{{ site.newsletter.corporateLabel }}</p>
          <p style="font-size:0.88rem;color:white;line-height:1.7">{{ site.newsletter.corporateBody }}</p>
          <a href="mailto:{{ site.newsletter.corporateEmail }}" style="font-size:0.8rem;color:var(--navy);font-weight:600;margin-top:0.5rem;display:block;background:white;padding:0.5rem 1rem;border-radius:4px;text-align:center;text-decoration:none;margin-top:0.75rem">{{ site.newsletter.corporateEmail }}</a>
        </div>
        <div style="background:rgba(255,255,255,0.1);border-radius:8px;padding:1.25rem">
          <p style="font-size:0.65rem;font-weight:700;letter-spacing:2px;color:rgba(255,255,255,0.6);margin-bottom:0.4rem">{{ site.newsletter.affiliateLabel }}</p>
          <p style="font-size:0.88rem;color:white;line-height:1.7">{{ site.newsletter.affiliateBody }}</p>
        </div>
      </div>
    </div>
  </div>
</section>
