---
layout: layout.njk
pageTitle: Shop
currentPage: /shop/
---

<!-- ── PALETTE STRIP ── -->
<div class="palette-strip">
  <div class="ps" style="background:#0A1A30"></div>
  <div class="ps" style="background:#152E5E"></div>
  <div class="ps" style="background:#C4580A"></div>
  <div class="ps" style="background:#D4920A"></div>
  <div class="ps" style="background:#6ABAE0"></div>
  <div class="ps" style="background:#2A9E6A"></div>
  <div class="ps" style="background:#F0E6D2"></div>
</div>

<!-- ── PAGE HERO ── -->
<div class="page-hero">
  <p class="page-hero-eyebrow">The Shop</p>
  <h1 class="page-hero-title">Teachings that<br><em>check you</em></h1>
  <p class="page-hero-sub">eBooks, crystal kits, and courses — every tool you need to release what's blocking you.</p>
</div>

<!-- ── EBOOKS ── -->
<section class="section shop">
  <div class="container">
    <p class="section-label">eBooks</p>
    <h2 class="section-title">The Phook Library</h2>
    <p class="section-body">Five teachings. Direct, honest, and built to check the ego you've been carrying. No fluff — just truth with breath.</p>
    <div class="book-grid">
      {% for book in site.shop.books %}
      <div class="book-card">
        <div class="book-cover {{ book.colorClass }}"><div class="book-cover-title">{{ book.title }}</div></div>
        <div class="book-body">
          <div class="book-tag">{{ book.tag }}</div>
          <div style="font-family:'Playfair Display',serif;font-size:0.9rem;font-weight:700;color:var(--navy)">{{ book.title }}</div>
          <div class="book-price">{{ book.price }}</div>
          <button class="book-btn">Buy Now</button>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ── CRYSTAL KITS ── -->
<section class="section crystal">
  <div class="container">
    <p class="section-label" style="color:var(--jade)">Crystal Kits</p>
    <h2 class="section-title" style="color:var(--beige)">The Crystal Phook Clearing</h2>
    <p class="section-body" style="color:rgba(240,230,210,0.6);margin-bottom:2.5rem">Physical tools for energetic work. Each stone is curated to support a specific Phook Principle — anchors for intention, not decoration.</p>
    <div class="crystal-grid">
      {% for item in site.crystal.items %}
      <div class="crystal-card">
        <div class="crystal-gem">{{ item.emoji }}</div>
        <div class="crystal-name">{{ item.name }}</div>
        <p class="crystal-desc">{{ item.desc }}</p>
      </div>
      {% endfor %}
    </div>
    <div style="margin-top:2.5rem;display:flex;gap:1rem;flex-wrap:wrap">
      <a href="#" class="btn-primary">The Full Clearing Kit — $49</a>
      <a href="#" class="btn-ghost" style="color:var(--jade);border-color:var(--jade)">Starter Kit — $24.99</a>
    </div>
  </div>
</section>

<!-- ── PHOOK IT SERIES ── -->
<section class="section series">
  <div class="container">
    <p class="section-label" style="color:var(--sky)">Mixed Format</p>
    <h2 class="section-title" style="color:var(--beige)">The Phook It Series</h2>
    <div class="series-grid">
      {% for item in site.series.items %}
      <div class="series-card">
        <span class="series-type">{{ item.type }}</span>
        <div class="series-title">{{ item.title }}</div>
        <div class="series-price">{{ item.price }}</div>
      </div>
      {% endfor %}
    </div>
    <div class="series-bundle">
      <div class="bundle-text">
        <div class="bundle-title">{{ site.series.bundle.title }}</div>
        <div class="bundle-sub">{{ site.series.bundle.sub }}</div>
      </div>
      <div>
        <div class="bundle-price">{{ site.series.bundle.price }}</div>
        <div class="bundle-save">{{ site.series.bundle.save }}</div>
      </div>
      <a href="#" class="btn-primary">{{ site.series.bundle.ctaLabel }}</a>
    </div>
  </div>
</section>

<!-- ── GROUP COURSE ── -->
<section class="section drama">
  <div class="container">
    <p class="section-label">Group & Corporate</p>
    <h2 class="section-title">Phook the Drama</h2>
    <p class="section-body">Eight modules for teams, workplaces, and any group of humans trying to function together without the drama. Available as a self-guided course or a live corporate workshop.</p>
    <div class="module-grid" style="margin-top:2rem">
      {% for mod in site.drama.modules %}
      <div class="module-card">
        <div class="module-num">{{ mod.num }}</div>
        <div class="module-title">{{ mod.title }}</div>
        <p class="module-text">{{ mod.text }}</p>
      </div>
      {% endfor %}
    </div>
    <div style="margin-top:2.5rem;display:flex;gap:1rem;flex-wrap:wrap">
      <a href="#" class="btn-primary">Full Course — $149</a>
      <a href="/contact/" class="btn-ghost" style="border-color:var(--copper);color:var(--copper)">Corporate Packages →</a>
    </div>
  </div>
</section>
