<script>
const toggle = document.querySelector('.nav-toggle');
const navLinks = document.querySelector('.nav-links');
if(toggle){
  toggle.addEventListener('click', () => {
    const open = navLinks.style.display === 'flex';
    navLinks.style.display = open ? 'none' : 'flex';
    navLinks.style.flexDirection = 'column';
    navLinks.style.position = 'absolute';
    navLinks.style.top = '68px';
    navLinks.style.left = '0';
    navLinks.style.right = '0';
    navLinks.style.background = 'rgba(240,230,210,0.98)';
    navLinks.style.padding = '1rem 2rem 1.5rem';
    navLinks.style.borderBottom = '1px solid #D5C4A8';
    navLinks.style.zIndex = '199';
    if(open) navLinks.style.display = 'none';
  });
}
document.querySelectorAll('.book-card,.teaching-card,.principle-card,.crystal-card,.module-card,.tier-card,.series-card,.test-card,.stat-card').forEach(el => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(20px)';
  el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
  new IntersectionObserver((entries) => {
    entries.forEach(e => { if(e.isIntersecting){ e.target.style.opacity='1'; e.target.style.transform='translateY(0)'; } });
  }, { threshold: 0.1 }).observe(el);
});
</script>
