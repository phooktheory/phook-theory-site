<!-- ── CONTACT SECTION ── -->
<section class="section" style="background:var(--cream)">
  <div class="container">
    <div class="two-col" style="align-items:start">

      <!-- FORM -->
      <div>
        <p class="section-label">Send a Message</p>
        <h2 class="section-title">Ask us anything</h2>
        <p class="section-body" style="margin-bottom:2rem">Fill in the form and we'll get back to you. Whether it's a question about the teachings, a product enquiry, or something else entirely — we read every message.</p>
        <form class="contact-form" name="contact" method="POST" data-netlify="true" action="/contact/?success=true">
          <input type="hidden" name="form-name" value="contact"/>
          <div class="form-group">
            <label class="form-label" for="name">Your Name</label>
            <input class="form-input" type="text" id="name" name="name" placeholder="Pamala Hook" required/>
          </div>
          <div class="form-group">
            <label class="form-label" for="email">Email Address</label>
            <input class="form-input" type="email" id="email" name="email" placeholder="your@email.com" required/>
          </div>
          <div class="form-group">
            <label class="form-label" for="subject">Subject</label>
            <input class="form-input" type="text" id="subject" name="subject" placeholder="What's on your mind?"/>
          </div>
          <div class="form-group">
            <label class="form-label" for="message">Your Question or Message</label>
            <textarea class="form-textarea" id="message" name="message" placeholder="Ask us anything..." required></textarea>
          </div>
          <button type="submit" class="btn-primary form-submit">Send Message</button>
        </form>
      </div>

      <!-- CONTACT INFO -->
      <div style="display:flex;flex-direction:column;gap:1.25rem;padding-top:4rem">
        <div style="background:white;border:1px solid var(--border);border-radius:8px;padding:1.5rem">
          <p style="font-size:0.65rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--copper);margin-bottom:0.5rem">General Enquiries</p>
          <p style="font-size:0.88rem;color:var(--smoke);line-height:1.7;margin-bottom:0.75rem">Questions about products, teachings, or anything Phook Theory.</p>
          <a href="mailto:hello@phooktheory.com" style="font-size:0.9rem;font-weight:600;color:var(--copper);text-decoration:none">hello@phooktheory.com</a>
        </div>
        <div style="background:white;border:1px solid var(--border);border-radius:8px;padding:1.5rem">
          <p style="font-size:0.65rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--copper);margin-bottom:0.5rem">Corporate Enquiries</p>
          <p style="font-size:0.88rem;color:var(--smoke);line-height:1.7;margin-bottom:0.75rem">For Phook the Drama packages, team workshops, and speaking engagements.</p>
          <a href="mailto:hello@phooktheory.com" style="font-size:0.9rem;font-weight:600;color:var(--copper);text-decoration:none">hello@phooktheory.com</a>
        </div>
        <div style="background:white;border:1px solid var(--border);border-radius:8px;padding:1.5rem">
          <p style="font-size:0.65rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--copper);margin-bottom:0.5rem">Affiliate Applications</p>
          <p style="font-size:0.88rem;color:var(--smoke);line-height:1.7;margin-bottom:0.75rem">Ready to become a Phook Partner? Use the form or visit the affiliate page.</p>
          <a href="/affiliate/" style="font-size:0.88rem;font-weight:600;color:var(--navy);text-decoration:none;background:var(--beige);padding:0.45rem 1rem;border-radius:4px;display:inline-block;border:1px solid var(--border)">View Affiliate Programme →</a>
        </div>
        <div style="background:white;border:1px solid var(--border);border-radius:8px;padding:1.5rem">
          <p style="font-size:0.65rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--copper);margin-bottom:0.5rem">Response Time</p>
          <p style="font-size:0.88rem;color:var(--smoke);line-height:1.7">We aim to respond within 2 business days. For urgent matters, email us directly at hello@phooktheory.com.</p>
        </div>
      </div>
    </div>
  </div>
</section>
