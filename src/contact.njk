<!-- ── PAGE HERO ── -->
<div class="page-hero">
  <p class="page-hero-eyebrow">Get in Touch</p>
  <h1 class="page-hero-title">We'd love to<br><em>hear from you</em></h1>
  <p class="page-hero-sub">Questions, corporate enquiries, affiliate applications, or just a truth to share — this is the place.</p>
